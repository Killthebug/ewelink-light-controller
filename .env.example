# Your eWeLink credentials (keep this file private, never commit to git)
# Use the SAME email & password you use in the eWeLink mobile app
# You do NOT need a developer account — the app uses official eWeLink credentials
EWELINK_EMAIL=your_email@example.com
EWELINK_PASSWORD=your_password

# Optional: force a specific region (auto-detected if omitted)
# Options: us, eu, as
# EWELINK_REGION=us

PORT=3456
HOST=0.0.0.0
