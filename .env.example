# ── eWeLink Developer Credentials ────────────────────────────
# Register at https://dev.ewelink.cc → Create app → Copy APP_ID & APP_SECRET
# Add a redirect URL (e.g. https://127.0.0.1:8888) — it will not actually be used
EWELINK_APP_ID=your_app_id_here
EWELINK_APP_SECRET=your_app_secret_here

# ── eWeLink Account ──────────────────────────────────────────
# Use the SAME email & password as the eWeLink mobile app
EWELINK_EMAIL=your_email@example.com
EWELINK_PASSWORD=your_password

# ── Optional ─────────────────────────────────────────────────
# Redirect URL for OAuth2 (must match what you set at dev.ewelink.cc)
# EWELINK_REDIRECT_URL=https://127.0.0.1:8888

PORT=3456
HOST=0.0.0.0
